# VipimoAI development environment example
# Copy to .env and fill values before running local services

# Django
DEBUG=True
SECRET_KEY=django-insecure-replace-me

# Database (PostGIS via docker-compose)
DB_ENGINE=postgis
DATABASE_URL=postgres://vipimoai:vipimoai@postgis:5432/vipimoai

# Celery / Redis
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Media
MEDIA_ROOT=/app/media
MEDIA_URL=/media/

# Vision LLM (OpenRouter/OpenAI)
OPENROUTER_API_KEY=
OPENROUTER_API_BASE=https://openrouter.ai

# Optional S3 toggle for later
USE_S3=False
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=
